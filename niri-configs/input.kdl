   cursor {
       xcursor-size 24
   }

input {
    keyboard {
        xkb {
            layout "us"
        }
    }

    focus-follows-mouse

    mouse {
        accel-speed 0.0
        accel-profile "flat"
    }

    touchpad {
        // natural-scroll omitted = disabled, matching natural_scroll = false
    }

}
